# Project data (DO NOT commit corpora and built artifacts)
# Corpora are typically third-party copyrighted material; keep them out.
*.db
*.sqlite
*.sqlite3
*.pkl
*.pickle
*.bin
corpus/
corpora/
data/
*.txt
*.fb2
*.epub
*.pdf
*.mobi

# But keep example/test fixtures if explicitly included:
!tests/fixtures/**/*.txt
!examples/**/*.txt

# Logs
*.log
logs/

# Local scratch / outputs
out/
output/
outputs/
scratch/
tmp/
.tmp/
